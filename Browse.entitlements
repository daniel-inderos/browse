<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow WebKit's JavaScriptCore JIT to map writable-then-executable memory -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow loading WebKit helper processes that aren't signed with the same Team ID -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Allow unsigned executable memory (fallback for older JIT paths) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
